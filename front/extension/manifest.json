{
  "name": "DRMaker",
  "version": "1.0.0",
  "manifest_version": 3,
  "description": "個人日報用",
  "icons": {
    "16": "icons/icon-192.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "contextMenus"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/content.js"],
      "all_frames": true,
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}